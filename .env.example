# The AI OS — secrets. Copy to .env and fill in. NEVER commit .env.
# `aios setup` generates .env for you; this file documents every key.

# ── Model provider (one key powers all four agents) ─────────────────────────
AIOS_LLM_PROVIDER=openrouter          # openrouter | anthropic | openai | gemini
AIOS_LLM_API_KEY=                     # the key for the provider above
AIOS_DEFAULT_MODEL=anthropic/claude-opus-4.6

# ── Optional explicit passthrough keys (used as-is if set) ──────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# ── opencode headless server auth (optional; blank = unsecured localhost) ───
OPENCODE_SERVER_PASSWORD=

# ── openclaw gateway auth (blank = auto-generate on first start) ────────────
OPENCLAW_GATEWAY_TOKEN=

# ── Channels (optional; only set what you enable) ───────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
